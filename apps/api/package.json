    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.3",
    "openai": "^5.8.2",
    "socket.io": "^4.8.1",
    "zod": "^3.25.67",
    "prisma": "^6.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
